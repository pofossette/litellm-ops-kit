LITELLM_PORT=4000
LITELLM_MASTER_KEY=auto-generated-on-init
DATABASE_URL=postgresql://litellm:litellm-local-password@postgres:5432/litellm
STORE_MODEL_IN_DB=True

POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm-local-password

# ── Main provider ──
MAIN_ANTHROPIC_API_BASE=https://your-main-anthropic-endpoint
MAIN_ANTHROPIC_API_KEY=replace-me
MAIN_OPENAI_API_BASE=https://your-main-openai-endpoint
MAIN_OPENAI_API_KEY=replace-me
MAIN_OPUS_MODEL=claude-opus-4-1
MAIN_SONNET_MODEL=claude-sonnet-4-5
MAIN_HAIKU_MODEL=claude-3-5-haiku-latest

# ── Fallback provider ──
FALLBACK_ANTHROPIC_API_BASE=https://your-fallback-anthropic-endpoint
FALLBACK_ANTHROPIC_API_KEY=replace-me
FALLBACK_OPENAI_API_BASE=https://your-fallback-openai-endpoint
FALLBACK_OPENAI_API_KEY=replace-me
FALLBACK_OPUS_MODEL=claude-opus-4-1
FALLBACK_SONNET_MODEL=claude-sonnet-4-5
FALLBACK_HAIKU_MODEL=claude-3-5-haiku-latest

# ── Optional extra fallback providers ──
FALLBACK2_ANTHROPIC_API_BASE=
FALLBACK2_ANTHROPIC_API_KEY=
FALLBACK2_OPENAI_API_BASE=
FALLBACK2_OPENAI_API_KEY=
FALLBACK2_OPUS_MODEL=
FALLBACK2_SONNET_MODEL=
FALLBACK2_HAIKU_MODEL=

FALLBACK3_ANTHROPIC_API_BASE=
FALLBACK3_ANTHROPIC_API_KEY=
FALLBACK3_OPENAI_API_BASE=
FALLBACK3_OPENAI_API_KEY=
FALLBACK3_OPUS_MODEL=
FALLBACK3_SONNET_MODEL=
FALLBACK3_HAIKU_MODEL=
