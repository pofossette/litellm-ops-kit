LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-local-gateway-change-me
DATABASE_URL=postgresql://litellm:litellm-local-password@postgres:5432/litellm
STORE_MODEL_IN_DB=True

POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm-local-password

# ── GLM Z.ai ──
GLM_ANTHROPIC_API_BASE=https://your-glm-anthropic-endpoint
GLM_ANTHROPIC_API_KEY=replace-me
GLM_OPENAI_API_BASE=https://your-glm-openai-endpoint
GLM_OPENAI_API_KEY=replace-me
GLM_OPUS_MODEL=claude-opus-4-1
GLM_SONNET_MODEL=claude-sonnet-4-5
GLM_HAIKU_MODEL=claude-3-5-haiku-latest

# ── JD Cloud ──
JD_ANTHROPIC_API_BASE=https://your-jd-anthropic-endpoint
JD_ANTHROPIC_API_KEY=replace-me
JD_OPENAI_API_BASE=https://your-jd-openai-endpoint
JD_OPENAI_API_KEY=replace-me
JD_OPUS_MODEL=claude-opus-4-1
JD_SONNET_MODEL=claude-sonnet-4-5
JD_HAIKU_MODEL=claude-3-5-haiku-latest
